{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": [
    "src/renderer/**/*",
    "src/core/**/*",
    "tests/unit/ai-chat-store.test.ts",
    "tests/unit/ai-model-options.test.ts",
    "tests/unit/app-store-profile-sync.test.ts"
  ]
}

---
import { copy } from '../content/copy'
---

<section id="why" class="why" data-testid="why">
  <h2 data-reveal>{copy.why.heading}</h2>
  <p class="lead" data-reveal>{copy.why.lead}</p>
  <div class="cards" data-reveal-group>
    {
      copy.why.points.map((p) => (
        <article class="card">
          <h3>{p.title}</h3>
          <p>{p.body}</p>
        </article>
      ))
    }
  </div>
  <a class="doc-link" href={copy.why.docsLink.href} data-reveal>{copy.why.docsLink.label} →</a>
</section>

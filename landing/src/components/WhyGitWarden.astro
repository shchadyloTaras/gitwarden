---
import { copy } from '../content/copy'
---

<section id="why" class="why" data-testid="why">
  <h2>{copy.why.heading}</h2>
  <p class="lead">{copy.why.lead}</p>
  <div class="cards">
    {
      copy.why.points.map((p) => (
        <article class="card">
          <h3>{p.title}</h3>
          <p>{p.body}</p>
        </article>
      ))
    }
  </div>
  <a class="doc-link" href={copy.why.docsLink.href}>{copy.why.docsLink.label} →</a>
</section>

---
import { copy } from '../content/copy'
import { formatBytes } from '../lib/format'
import type { OS, ResolvedTargets } from '../lib/types'

interface Props {
  resolved: ResolvedTargets
}

const { resolved } = Astro.props
const groups: OS[] = ['macOS', 'Windows', 'Linux']
---

<section id="downloads" class="all-downloads" data-testid="all-downloads">
  <h2>{copy.allDownloads.heading}</h2>
  <p class="subhead">{copy.allDownloads.subhead}</p>

  <div class="groups">
    {
      groups.map((os) => {
        const hasDl = resolved.all[os].length > 0
        return hasDl ? (
          <div class="group" data-testid={`downloads-${os}`}>
            <h3>{os}</h3>
            <ul>
              {resolved.all[os].map((t) => (
                <li>
                  <a href={t.url} data-testid={`asset-${t.filename}`}>
                    {t.label}
                  </a>
                  <span class="meta">
                    {t.ext}
                    {t.sizeBytes ? ` · ${formatBytes(t.sizeBytes)}` : ''}
                    {resolved.version ? ` · ${resolved.version}` : ''}
                  </span>
                </li>
              ))}
            </ul>
          </div>
        ) : (
          <a
            href={resolved.releaseUrl}
            class="group"
            data-testid={`downloads-${os}`}
            rel="noopener"
          >
            <h3>{os}</h3>
            <p class="empty">{copy.allDownloads.fallbackRow}</p>
          </a>
        )
      })
    }
  </div>

  <p class="all-fallback">
    <a href={resolved.releaseUrl} data-testid="all-downloads-fallback">
      {copy.allDownloads.fallbackRow}
    </a>
  </p>
</section>

---
import Base from '../layouts/Base.astro'
import DocsSidebar from './DocsSidebar.astro'

interface Props {
  title: string
  description: string
  currentSlug?: string
}

const { title, description, currentSlug } = Astro.props
const pageTitle = `${title} — GitWarden Docs`

// BreadcrumbList structured data: GitWarden › Documentation › <page>. Breadcrumbs are one of
// the few rich results Google still shows broadly. The docs index omits the third crumb.
const site = Astro.site ?? new URL('https://gitwarden.vercel.app')
const docsHome = new URL('/docs/', site)
const current = new URL(Astro.url.pathname, site)
const isDocsIndex = !currentSlug || currentSlug === 'index'
const crumbs = [
  { '@type': 'ListItem', position: 1, name: 'GitWarden', item: site.toString() },
  { '@type': 'ListItem', position: 2, name: 'Documentation', item: docsHome.toString() },
]
if (!isDocsIndex) {
  crumbs.push({ '@type': 'ListItem', position: 3, name: title, item: current.toString() })
}
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: crumbs,
}
---

<Base title={pageTitle} description={description}>
  <div class="docs-layout">
    <header class="docs-header">
      <div class="docs-header-inner">
        <a href="/" class="docs-brand">← GitWarden</a>
        <span class="docs-section-label">Documentation</span>
        <button
          type="button"
          class="docs-menu-btn"
          id="docs-menu-btn"
          aria-label="Toggle navigation menu"
          aria-expanded="false"
          aria-controls="docs-sidebar"
        >
          <span aria-hidden="true">☰</span>
        </button>
      </div>
    </header>

    <div class="docs-body">
      <DocsSidebar currentSlug={currentSlug} />
      <main id="top" class="docs-content">
        <article class="prose">
          <slot />
        </article>
      </main>
    </div>
  </div>

  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbLd)} />
</Base>

<script>
  const btn = document.getElementById('docs-menu-btn')
  const sidebar = document.getElementById('docs-sidebar')

  btn?.addEventListener('click', () => {
    const isOpen = sidebar?.classList.toggle('is-open') ?? false
    btn.setAttribute('aria-expanded', String(isOpen))
  })

  // Close sidebar when a nav link is clicked on mobile
  sidebar?.querySelectorAll('.docs-nav-link').forEach((link) => {
    link.addEventListener('click', () => {
      sidebar.classList.remove('is-open')
      btn?.setAttribute('aria-expanded', 'false')
    })
  })

  const copyWithFallback = async (text: string) => {
    if (navigator.clipboard?.writeText) {
      await navigator.clipboard.writeText(text)
      return
    }

    const textarea = document.createElement('textarea')
    textarea.value = text
    textarea.setAttribute('readonly', '')
    textarea.style.position = 'fixed'
    textarea.style.inset = '0 auto auto 0'
    textarea.style.opacity = '0'
    textarea.style.pointerEvents = 'none'
    document.body.append(textarea)
    textarea.select()

    try {
      const copied = document.execCommand('copy')
      if (!copied) throw new Error('Copy command was rejected')
    } finally {
      textarea.remove()
    }
  }

  document.querySelectorAll<HTMLElement>('.prose pre > code').forEach((code) => {
    const pre = code.parentElement
    if (!pre || pre.dataset.copyable === 'true') return
    const language = pre.dataset.language ?? code.dataset.language ?? ''
    const classNames = `${pre.className} ${code.className}`
    if (language !== 'bash' && !classNames.includes('language-bash')) return

    const button = document.createElement('button')
    button.type = 'button'
    button.className = 'code-copy-btn'
    button.textContent = 'Copy'
    button.setAttribute('aria-label', 'Copy terminal command')

    let resetTimer: number | undefined
    button.addEventListener('click', async () => {
      const command = code.textContent?.replace(/\n$/, '') ?? ''
      if (!command.trim()) return

      button.disabled = true
      window.clearTimeout(resetTimer)

      try {
        await copyWithFallback(command)
        button.textContent = 'Copied'
        button.setAttribute('aria-label', 'Copied terminal command')
      } catch {
        button.textContent = 'Failed'
        button.setAttribute('aria-label', 'Copy failed')
      } finally {
        button.disabled = false
        resetTimer = window.setTimeout(() => {
          button.textContent = 'Copy'
          button.setAttribute('aria-label', 'Copy terminal command')
        }, 1600)
      }
    })

    pre.dataset.copyable = 'true'
    pre.append(button)
  })
</script>

---
import { copy } from '../content/copy'
import {
  REPO_URL,
  RELEASES_URL,
  SECURITY_URL,
  LICENSE_URL,
  SUPPORT_MAILTO_URL,
} from '../lib/config'
import type { ResolvedTargets } from '../lib/types'

interface Props {
  resolved: ResolvedTargets
}

const { resolved } = Astro.props
const links = [
  { label: copy.footer.links.support, href: SUPPORT_MAILTO_URL },
  { label: copy.footer.links.github, href: REPO_URL },
  { label: copy.footer.links.releases, href: RELEASES_URL },
  { label: copy.footer.links.security, href: SECURITY_URL },
  { label: copy.footer.links.license, href: LICENSE_URL },
]
---

<footer class="site-footer" data-testid="footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <p class="brand">
        <img src="/favicon.svg" alt="" aria-hidden="true" width="22" height="22" />
        {copy.productName}
      </p>
      <p class="muted">{copy.footer.tagline}</p>
    </div>
    <nav class="footer-links" aria-label="Footer">
      {
        links.map((l) => (
          <a
            href={l.href}
            rel={l.href.startsWith('http') ? 'noopener' : undefined}
            target={l.href.startsWith('http') ? '_blank' : undefined}
          >
            {l.label}
          </a>
        ))
      }
    </nav>
  </div>
  <div class="footer-meta">
    <a class="version-badge" href={resolved.releaseUrl} data-testid="footer-version">
      {resolved.version ? `${copy.footer.latestPrefix} ${resolved.version}` : copy.footer.noRelease}
    </a>
    <span class="muted">{copy.footer.license}</span>
  </div>
</footer>

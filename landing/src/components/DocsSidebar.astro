---
import { getCollection } from 'astro:content'

interface Props {
  currentSlug?: string
}
const { currentSlug } = Astro.props

const entries = await getCollection('docs')
const navItems = entries
  .sort((a, b) => a.data.order - b.data.order)
  .map((entry) => ({
    id: entry.id,
    title: entry.data.title,
    href: entry.id === 'index' ? '/docs' : `/docs/${entry.id}`,
  }))

const isActive = (id: string) => id === (currentSlug ?? 'index') || (id === 'index' && !currentSlug)
---

<nav class="docs-sidebar" id="docs-sidebar" aria-label="Documentation navigation">
  <ul class="docs-nav" role="list">
    {
      navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class:list={['docs-nav-link', { 'is-active': isActive(item.id) }]}
            aria-current={isActive(item.id) ? 'page' : undefined}
          >
            {item.title}
          </a>
        </li>
      ))
    }
  </ul>
</nav>

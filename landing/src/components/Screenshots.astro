---
import { Image } from 'astro:assets'
import { copy } from '../content/copy'
import statusDark from '../assets/screenshots/status-dark.webp'
import repositoriesLight from '../assets/screenshots/repositories-light.webp'

// Real app captures, optimized at build time by astro:assets. Paired with the
// copy entries by order (dark Status, then light Repositories — see copy.ts).
const images = [statusDark, repositoriesLight]
const shots = copy.screenshots.shots.map((shot, i) => ({ ...shot, image: images[i] }))
---

<section id="screenshots" class="screenshots" data-testid="screenshots">
  <h2>{copy.screenshots.heading}</h2>
  <p class="subhead">{copy.screenshots.subhead}</p>
  <div class="shots">
    {
      shots.map((s) => (
        <figure>
          <Image src={s.image} alt={s.alt} width={1280} loading="lazy" decoding="async" />
          <figcaption>{s.caption}</figcaption>
        </figure>
      ))
    }
  </div>
</section>

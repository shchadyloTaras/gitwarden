---
import Base from '../layouts/Base.astro'
import Header from '../components/Header.astro'
import DownloadHero from '../components/DownloadHero.astro'
import WhyGitWarden from '../components/WhyGitWarden.astro'
import Features from '../components/Features.astro'
import Screenshots from '../components/Screenshots.astro'
import AllDownloads from '../components/AllDownloads.astro'
import InstallSteps from '../components/InstallSteps.astro'
import Faq from '../components/Faq.astro'
import Footer from '../components/Footer.astro'
import { getReleaseForBuild } from '../lib/getRelease'
import { resolveTargets } from '../lib/resolveTargets'

// Build-time resolution (plan §3). `unknown` OS server-side → no primary; the client island
// in DownloadHero enhances per detected OS. The all-downloads panel uses the full `all` map.
const release = await getReleaseForBuild()
const resolved = resolveTargets(release, 'unknown')
---

<Base>
  <Header />
  <main id="top" class="page">
    <DownloadHero resolved={resolved} release={release} />
    <WhyGitWarden />
    <Features />
    <Screenshots />
    <AllDownloads resolved={resolved} />
    <InstallSteps />
    <Faq />
  </main>
  <Footer resolved={resolved} />
</Base>

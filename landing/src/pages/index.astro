---
import Base from '../layouts/Base.astro'
import Header from '../components/Header.astro'
import DownloadHero from '../components/DownloadHero.astro'
import WhyGitWarden from '../components/WhyGitWarden.astro'
import Features from '../components/Features.astro'
import Screenshots from '../components/Screenshots.astro'
import AllDownloads from '../components/AllDownloads.astro'
import InstallSteps from '../components/InstallSteps.astro'
import Faq from '../components/Faq.astro'
import Footer from '../components/Footer.astro'
import { copy } from '../content/copy'
import { REPO_URL, RELEASES_URL, LICENSE_URL } from '../lib/config'
import { getReleaseForBuild } from '../lib/getRelease'
import { resolveTargets } from '../lib/resolveTargets'

// Build-time resolution (plan §3). `unknown` OS server-side → no primary; the client island
// in DownloadHero enhances per detected OS. The all-downloads panel uses the full `all` map.
const release = await getReleaseForBuild()
const resolved = resolveTargets(release, 'unknown')

// JSON-LD structured data (plan §5).
const siteUrl = Astro.site?.toString() ?? REPO_URL
const softwareLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: copy.productName,
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'macOS, Windows, Linux',
  description: copy.meta.description,
  url: siteUrl,
  downloadUrl: RELEASES_URL,
  license: LICENSE_URL,
  isAccessibleForFree: true,
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
}
const websiteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: copy.productName,
  url: siteUrl,
}
// FAQPage structured data — mirrors the on-page FAQ. Valid markup that feeds AI/answer engines;
// classic FAQ rich results are limited since Google's 2023 change, but the cost here is nil.
const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: copy.faq.items.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
}
---

<Base>
  <Header />
  <main id="top" class="page">
    <DownloadHero resolved={resolved} release={release} />
    <WhyGitWarden />
    <Features />
    <Screenshots />
    <AllDownloads resolved={resolved} />
    <InstallSteps />
    <Faq />
  </main>
  <Footer resolved={resolved} />

  <script type="application/ld+json" is:inline set:html={JSON.stringify(softwareLd)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(websiteLd)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqLd)} />
</Base>

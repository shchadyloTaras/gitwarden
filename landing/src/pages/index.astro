---
import Base from '../layouts/Base.astro'
import { copy } from '../content/copy'
---

<Base>
  <main
    class="mx-auto flex min-h-screen max-w-3xl flex-col items-center justify-center px-6 text-center"
  >
    <p class="mb-3 text-sm font-medium tracking-widest text-gw-accent uppercase">
      {copy.productName}
    </p>
    <h1 class="text-4xl font-bold tracking-tight text-balance sm:text-5xl">
      {copy.tagline}
    </h1>
    <p class="mt-6 max-w-xl text-lg text-gw-text-muted">
      {copy.heroSubtitle}
    </p>
  </main>
</Base>

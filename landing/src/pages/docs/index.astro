---
import { getEntry, render } from 'astro:content'
import DocsLayout from '../../components/DocsLayout.astro'

const entry = await getEntry('docs', 'index')
if (!entry) throw new Error('src/content/docs/index.md is missing')
const { Content } = await render(entry)
---

<DocsLayout title={entry.data.title} description={entry.data.description} currentSlug="index">
  <Content />
</DocsLayout>

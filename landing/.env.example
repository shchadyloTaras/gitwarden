# Landing site environment. Copy to `.env` to enable. All PUBLIC_* vars are exposed to the
# client bundle (never put secrets here). Everything is OFF by default when unset.

# Cookieless analytics (Plausible) — no cookies, no PII. Set to your verified domain to enable.
# Leave unset and no analytics script is emitted at all.
# PUBLIC_PLAUSIBLE_DOMAIN=gitwarden.vercel.app

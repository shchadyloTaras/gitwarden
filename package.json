  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "test": "vitest run",
    "e2e": "electron-vite build && playwright test",
    "lint": "eslint . --ext .ts,.tsx && prettier --check .",
